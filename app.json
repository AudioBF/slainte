{
  "expo": {
    "name": "Sláinte",
    "slug": "slainte",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "slainte",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "O Sláinte usa a câmera para fotografar suas refeições.",
        "NSPhotoLibraryUsageDescription": "O Sláinte acessa suas fotos para analisar refeições."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B4332",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Sláinte — nutrição em Dublin",
      "shortName": "Sláinte",
      "description": "Planeje refeições, registre pratos e acompanhe macros.",
      "themeColor": "#1B4332",
      "backgroundColor": "#1B4332",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "pt-BR"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Sláinte acessa suas fotos para analisar refeições.",
          "cameraPermission": "O Sláinte usa a câmera para fotografar suas refeições."
        }
      ],
      "expo-image"
    ]
  }
}
