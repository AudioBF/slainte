# Deprecated client-side Gemini key.
# Sprint 1A/1B route meal photo analysis and shopping list through Supabase Edge Functions.
# Sprint 1C can route meal plan through Edge behind EXPO_PUBLIC_USE_EDGE_MEAL_PLAN.
# Keep this temporarily for meal plan rollback while the Edge path is validated.
EXPO_PUBLIC_GEMINI_API_KEY=

# Set to "false" to use real AI calls (default: mock mode)
EXPO_PUBLIC_AI_MOCK=true

# Set to "true" to use Supabase Edge Function for meal plan generation.
# Keep "false" or unset to use the temporary client-side Gemini rollback path.
EXPO_PUBLIC_USE_EDGE_MEAL_PLAN=false

# Supabase (Fase 4) — https://supabase.com/dashboard
# Run supabase/schema.sql in the SQL Editor after creating a project
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Edge Function secret (do NOT put this in Expo/Vercel public env):
# supabase secrets set GEMINI_API_KEY=AIza...
