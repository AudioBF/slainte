# Gemini API key — create at https://aistudio.google.com/apikey
# Must start with AIza... (Google AI Studio key)
EXPO_PUBLIC_GEMINI_API_KEY=

# Set to "false" to use real Gemini when API key is present (default: mock mode)
EXPO_PUBLIC_AI_MOCK=true

# Supabase (Fase 4) — https://supabase.com/dashboard
# Run supabase/schema.sql in the SQL Editor after creating a project
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
