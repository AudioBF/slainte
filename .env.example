# Deprecated client-side Gemini key.
# Sprint 1A routes meal photo analysis through Supabase Edge Functions.
# Keep this temporarily only because meal plan/shopping still use the rollback client path.
EXPO_PUBLIC_GEMINI_API_KEY=

# Set to "false" to use real AI calls (default: mock mode)
EXPO_PUBLIC_AI_MOCK=true

# Supabase (Fase 4) — https://supabase.com/dashboard
# Run supabase/schema.sql in the SQL Editor after creating a project
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Edge Function secret (do NOT put this in Expo/Vercel public env):
# supabase secrets set GEMINI_API_KEY=AIza...
